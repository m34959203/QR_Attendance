# === Database ===
DATABASE_URL=postgresql://wagateway:wagateway_secret@localhost:5432/wagateway
DB_PASSWORD=wagateway_secret

# === Redis ===
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# === API ===
API_PORT=3100
API_HOST=0.0.0.0
NODE_ENV=development

# === Security ===
# Master key for creating instances (min 16 chars)
MASTER_API_KEY=change-me-to-a-secure-key-at-least-16-chars
# AES-256 key for session encryption (hex, 64 chars)
SESSION_ENCRYPTION_KEY=

# === MinIO / S3 (media storage) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# === Webhook ===
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# === Rate Limiting ===
RATE_LIMIT_SEND_PER_MIN=100
RATE_LIMIT_READ_PER_MIN=1000

# === Anti-spam ===
MIN_DELAY_BETWEEN_MESSAGES_MS=1000

# === Worker ===
SESSIONS_DIR=./sessions
METRICS_PORT=9090

# === Monitoring (production) ===
GRAFANA_PASSWORD=admin
