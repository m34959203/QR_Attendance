# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

PORT=3000

# URL по которому ученики открывают страницу после скана QR
# Локальный Wi-Fi: http://192.168.1.100:3000
# VPS с доменом:   https://school.example.kz
BASE_URL=http://localhost:3000

TIMEZONE=Asia/Almaty
ADMIN_PASSWORD=замените_на_сложный_пароль
SCHOOL_NAME=Учебный центр

# WhatsApp провайдер: baileys (по умолчанию — бесплатный), greenapi, twilio, wwebjs
# baileys    — прямое подключение через QR в админке (бесплатно)
# greenapi   — через сервис green-api.com (платный)
WA_PROVIDER=baileys

# Green API — https://green-api.com (если WA_PROVIDER=greenapi)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
# Кастомный API URL (из кабинета Green API, поле apiUrl). По умолчанию: https://api.green-api.com
# GREEN_API_URL=https://7107.api.greenapi.com

# Twilio — https://twilio.com (если WA_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Хранение данных: удалять записи старше N лет (0 = не удалять)
DATA_RETENTION_YEARS=2

# ── Email (SMTP) — опционально ───────────────────────────────────────
# Gmail:  SMTP_HOST=smtp.gmail.com SMTP_PORT=465
# Yandex: SMTP_HOST=smtp.yandex.ru SMTP_PORT=465
# Mail.ru:SMTP_HOST=smtp.mail.ru   SMTP_PORT=465
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
